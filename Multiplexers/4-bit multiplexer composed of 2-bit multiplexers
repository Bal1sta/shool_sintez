module wide_mux_from_narrow_muxes
(
  input  [3:0] d0, d1, d2, d3,
  input  [1:0] sel,
  output [3:0] y
);

  wire [1:0] lo;
  wire [1:0] hi;

  mux_4_1_width_2 mux_lo (
    .d0(d0[1:0]),
    .d1(d1[1:0]),
    .d2(d2[1:0]),
    .d3(d3[1:0]),
    .sel(sel),
    .y(lo)
  );

  mux_4_1_width_2 mux_hi (
    .d0(d0[3:2]),
    .d1(d1[3:2]),
    .d2(d2[3:2]),
    .d3(d3[3:2]),
    .sel(sel),
    .y(hi)
  );

  assign y = {hi, lo};

endmodule