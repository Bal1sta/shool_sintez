module shift_register_with_valid
# (
    parameter width = 8,
    parameter depth = 8
)
(
    input  logic                    clk,
    input  logic                    rst,

    input  logic                    in_vld,
    input  logic [width - 1:0]      in_data,

    output logic                    out_vld,
    output logic [width - 1:0]      out_data
);

    logic [width-1:0] data_shift [depth-1:0];
    logic             valid_shift[depth-1:0];

    integer i;

    always_ff @(posedge clk or posedge rst) begin
        if (rst) begin
            for (i = 0; i < depth; i++) begin
                data_shift[i]  <= '0;
                valid_shift[i] <= 1'b0;
            end
        end
        else begin
            // всегда сдвигаем
            data_shift[0]  <= in_data;
            valid_shift[0] <= in_vld;

            for (i = 1; i < depth; i++) begin
                data_shift[i]  <= data_shift[i-1];
                valid_shift[i] <= valid_shift[i-1];
            end
        end
    end

    assign out_data = data_shift[depth-1];
    assign out_vld  = valid_shift[depth-1];

endmodule