module serial_adder_with_vld
(
  input  clk,
  input  rst,
  input  vld,
  input  a,
  input  b,
  input  last,
  output sum
);

  logic carry;
  wire carry_d;

  assign sum     = a ^ b ^ carry;
  assign carry_d = (a & b) | (a & carry) | (b & carry);

  always_ff @(posedge clk)
    if (rst)
      carry <= 1'b0;
    else if (vld)
      if (last)
        carry <= 1'b0;
      else
        carry <= carry_d;

endmodule