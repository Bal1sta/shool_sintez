module gearbox_2_to_1_fc
# (
    parameter width = 8
)
(
    input                      clk,
    input                      rst,

    input                      up_valid,
    output logic               up_ready,
    input      [2*width - 1:0] up_data,

    output logic               down_valid,
    input                      down_ready,
    output logic [width - 1:0] down_data
);

    logic [2*width - 1:0] data_reg;
    logic                 busy;
    logic                 part_sel; // 0 = старшая половина, 1 = младшая

    always_ff @(posedge clk or posedge rst) begin
        if (rst) begin
            data_reg  <= '0;
            busy      <= 1'b0;
            part_sel  <= 1'b0;
        end
        else begin
            // прием нового широкого слова
            if (!busy && up_valid) begin
                data_reg <= up_data;
                busy     <= 1'b1;
                part_sel <= 1'b0;
            end
            // выдача узких слов
            else if (busy && down_valid && down_ready) begin
                if (part_sel == 1'b0) begin
                    part_sel <= 1'b1;   // после старшей половины выдаем младшую
                end
                else begin
                    busy     <= 1'b0;   // после младшей половины освобождаемся
                    part_sel <= 1'b0;
                end
            end
        end
    end

    always_comb begin
        up_ready   = !busy;
        down_valid = busy;

        if (!busy) begin
            down_data = '0;
        end
        else if (part_sel == 1'b0) begin
            down_data = data_reg[2*width-1:width]; // старшие биты
        end
        else begin
            down_data = data_reg[width-1:0];       // младшие биты
        end
    end

endmodule